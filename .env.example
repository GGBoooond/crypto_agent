# ============================================================
# Crypto Agent 配置文件示例
# 复制此文件为 .env 并填入您的配置
# ============================================================

# ============ 交易所配置 ============
OKX_API_KEY=your_api_key
OKX_SECRET_KEY=your_secret_key
OKX_PASSPHRASE=your_passphrase
OKX_ACCOUNT_TYPE=swap

# ============ AI / LLM 配置 ============
# 旧 DeepSeek 配置（保留向下兼容，未填写新 LLM_* 字段时自动作为默认值）
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_TEMPERATURE=0.3

# 通用 LLM Provider（推荐）。支持任意 OpenAI 协议兼容服务。
# provider 可选: deepseek | openai | openai_compatible
# 使用 OpenAI ChatGPT 示例:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-xxx
#   LLM_MODEL=gpt-4o-mini
# 使用其他兼容服务（Azure / 通义千问 / 本地 vLLM 等）示例:
#   LLM_PROVIDER=openai_compatible
#   LLM_API_KEY=your_key
#   LLM_BASE_URL=https://your.endpoint.com/v1
#   LLM_MODEL=any-model-id
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# DeepSeek V4 系列默认开启思维链；结构化 JSON 输出场景建议关闭以避免
# 思考链消耗全部 token 导致 message.content 为空。
LLM_THINKING_ENABLED=false

# ============ Reviewer LLM / LLM-as-Judge 配置 ============
# 用于 Postmortem 归因和 Skill Patch 双签，必须和上面的策略 LLM 不同。
# 如果策略 LLM 是 deepseek-chat，这里可以用 qwen / glm / openai / openai_compatible。
# provider 可选: qwen | glm | openai | openai_compatible
POSTMORTEM_REVIEWER_PROVIDER=qwen
POSTMORTEM_REVIEWER_API_KEY=
POSTMORTEM_REVIEWER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
POSTMORTEM_REVIEWER_MODEL=qwen-plus
LLM_REVIEWER_DAILY_TOKEN_LIMIT=50000
# true 表示 reviewer 没配好时降级到规则评分；实盘前建议改成 false，让配置错误直接暴露。
EVOLUTION_REVIEWER_DEGRADED=true

# ============ Evolution 离线调度配置 ============
# 默认关闭；打开后 main.py 会每天跑 attribution / lifecycle / postmortem。
EVOLUTION_SCHEDULER_ENABLED=false
EVOLUTION_ATTRIBUTION_HOUR_UTC=0
EVOLUTION_ATTRIBUTION_MINUTE=30
EVOLUTION_LIFECYCLE_HOUR_UTC=0
EVOLUTION_LIFECYCLE_MINUTE=45
EVOLUTION_POSTMORTEM_HOUR_UTC=1
EVOLUTION_POSTMORTEM_MINUTE=0
LIFECYCLE_STRONG_DAYS_TO_ACTIVE=3

# ============ 交易配置 ============
TRADING_SYMBOL=DOGE/USDT:USDT
TRADING_AMOUNT=100
TRADING_LEVERAGE=5
TRADING_TIMEFRAME=1m
TRADING_INTERVAL=120
TEST_MODE=true

# ============ 策略配置 ============
# 可用策略: ai_scalping, ai, technical, trend
ENABLED_STRATEGIES=ai_scalping
STRATEGY_MODE=single
VOTE_THRESHOLD=0.4

# ============ AI剥头皮参数 ============
SCALPING_MIN_PROFIT=0.3
SCALPING_MAX_LOSS=0.5
SCALPING_HOLD_MINUTES=10

# ============ 风控配置 ============
MAX_POSITION_RATIO=0.3
STOP_LOSS_RATIO=0.02
DAILY_STOP_LOSS_RATIO=0.05
MAX_LEVERAGE=10
MAX_CONSECUTIVE_LOSSES=5
MAX_DAILY_TRADES=50

# ============ 稳定性配置 ============
RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=5
HEARTBEAT_INTERVAL=30

# ============ Web配置 ============
WEB_HOST=0.0.0.0
WEB_PORT=8888
