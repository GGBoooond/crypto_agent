# ============================================================
# Crypto Agent 配置文件示例
# 复制此文件为 .env 并填入您的配置
# ============================================================

# ============ 交易所配置 ============
OKX_API_KEY=your_api_key
OKX_SECRET_KEY=your_secret_key
OKX_PASSPHRASE=your_passphrase
OKX_ACCOUNT_TYPE=swap

# ============ AI配置 ============
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_TEMPERATURE=0.3

# ============ 交易配置 ============
TRADING_SYMBOL=DOGE/USDT:USDT
TRADING_AMOUNT=100
TRADING_LEVERAGE=5
TRADING_TIMEFRAME=1m
TRADING_INTERVAL=120
TEST_MODE=true

# ============ 策略配置 ============
# 可用策略: ai_scalping, ai, technical, trend
ENABLED_STRATEGIES=ai_scalping
STRATEGY_MODE=single
VOTE_THRESHOLD=0.4

# ============ AI剥头皮参数 ============
SCALPING_MIN_PROFIT=0.3
SCALPING_MAX_LOSS=0.5
SCALPING_HOLD_MINUTES=10

# ============ 风控配置 ============
MAX_POSITION_RATIO=0.3
STOP_LOSS_RATIO=0.02
DAILY_STOP_LOSS_RATIO=0.05
MAX_LEVERAGE=10
MAX_CONSECUTIVE_LOSSES=5
MAX_DAILY_TRADES=50

# ============ 稳定性配置 ============
RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=5
HEARTBEAT_INTERVAL=30

# ============ Web配置 ============
WEB_HOST=0.0.0.0
WEB_PORT=8888
