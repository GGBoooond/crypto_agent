# ============================================================
# Crypto Agent 配置文件示例
# 复制此文件为 .env 并填入您的配置
# ============================================================

# ============ 交易所配置 ============
OKX_API_KEY=your_api_key
OKX_SECRET_KEY=your_secret_key
OKX_PASSPHRASE=your_passphrase
OKX_ACCOUNT_TYPE=swap

# ============ AI / LLM 配置 ============
# 旧 DeepSeek 配置（保留向下兼容，未填写新 LLM_* 字段时自动作为默认值）
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_TEMPERATURE=0.3

# 通用 LLM Provider（推荐）。支持任意 OpenAI 协议兼容服务。
# provider 可选: deepseek | openai | openai_compatible
# 使用 OpenAI ChatGPT 示例:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-xxx
#   LLM_MODEL=gpt-4o-mini
# 使用其他兼容服务（Azure / 通义千问 / 本地 vLLM 等）示例:
#   LLM_PROVIDER=openai_compatible
#   LLM_API_KEY=your_key
#   LLM_BASE_URL=https://your.endpoint.com/v1
#   LLM_MODEL=any-model-id
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# DeepSeek V4 系列默认开启思维链；结构化 JSON 输出场景建议关闭以避免
# 思考链消耗全部 token 导致 message.content 为空。
LLM_THINKING_ENABLED=false

# ============ 交易配置 ============
TRADING_SYMBOL=DOGE/USDT:USDT
TRADING_AMOUNT=100
TRADING_LEVERAGE=5
TRADING_TIMEFRAME=1m
TRADING_INTERVAL=120
TEST_MODE=true

# ============ 策略配置 ============
# 可用策略: ai_scalping, ai, technical, trend
ENABLED_STRATEGIES=ai_scalping
STRATEGY_MODE=single
VOTE_THRESHOLD=0.4

# ============ AI剥头皮参数 ============
SCALPING_MIN_PROFIT=0.3
SCALPING_MAX_LOSS=0.5
SCALPING_HOLD_MINUTES=10

# ============ 风控配置 ============
MAX_POSITION_RATIO=0.3
STOP_LOSS_RATIO=0.02
DAILY_STOP_LOSS_RATIO=0.05
MAX_LEVERAGE=10
MAX_CONSECUTIVE_LOSSES=5
MAX_DAILY_TRADES=50

# ============ 稳定性配置 ============
RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=5
HEARTBEAT_INTERVAL=30

# ============ Web配置 ============
WEB_HOST=0.0.0.0
WEB_PORT=8888
